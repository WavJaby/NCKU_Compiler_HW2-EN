test/questions_en/05_village_arithmetic.wy:27:22   |    set 「繁花」 <- reg<i32>
test/questions_en/05_village_arithmetic.wy:29:65   |    PRINT: "歇腳之處，竟有"
test/questions_en/05_village_arithmetic.wy:29:65   |    PRINT: 「亭臺」
test/questions_en/05_village_arithmetic.wy:29:65   |    PRINT: "座之多。"
test/questions_en/05_village_arithmetic.wy:30:65   |    PRINT: "路邊繁花更盛，總計"
test/questions_en/05_village_arithmetic.wy:30:65   |    PRINT: 「繁花」
test/questions_en/05_village_arithmetic.wy:30:65   |    PRINT: "枝！"
