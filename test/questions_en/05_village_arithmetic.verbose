test/questions_en/05_village_arithmetic.wy:1:2     |> (scope id: 0, type: SCOPE_MAIN)
test/questions_en/05_village_arithmetic.wy:8:50    |    PRINT: "老夫今日不卜卦，且出城踏青，算算這山間野趣。"
test/questions_en/05_village_arithmetic.wy:10:40   |    PRINT: "一去二三里，煙村四五家。"
test/questions_en/05_village_arithmetic.wy:12:22   |    var 「去路」 <- 2
